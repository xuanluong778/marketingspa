// Prisma schema - MarketingSpa SaaS (multi-tenant)
// Mọi bảng nghiệp vụ đều gắn organizationId để cô lập dữ liệu theo spa

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  PROBATION
}

enum EmployeeStatus {
  ACTIVE
  PROBATION
  ON_LEAVE
  TERMINATED
}

enum HrmDocumentType {
  CONTRACT
  ID_CARD
  CERTIFICATE
  OTHER
}

enum EmploymentContractType {
  PROBATION
  FIXED
  INDEFINITE
}

enum EmploymentContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum AttendanceMethod {
  QR
  GPS
  KIOSK
  MANUAL
}

enum TimesheetStatus {
  OPEN
  LOCKED
  ARCHIVED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendancePunchType {
  CHECK_IN
  CHECK_OUT
  BREAK_START
  BREAK_END
}

enum AttendanceDayStatus {
  PRESENT
  ABSENT
  LEAVE
  HOLIDAY
  INCOMPLETE
}

enum ShiftAssignmentSource {
  POLICY
  MANUAL
  SWAP
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  MATERNITY
  OTHER
}

enum LeadPipelineStatus {
  NEW
  CONTACTED
  BOOKED
  VISITED
  PURCHASED
  LOST
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  ARRIVED
  NO_SHOW
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  DRAFT
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  MOMO
  ZALOPAY
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ExpenseCategory {
  ADVERTISING
  RENT
  SALARY
  SUPPLIES
  UTILITIES
  MAINTENANCE
  OTHER
}

enum AdPlatform {
  META
  GOOGLE
  TIKTOK
  ZALO
  MANUAL
  OTHER
}

enum AdCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum MessageChannel {
  EMAIL
  SMS
  ZALO
  MESSENGER
  PUSH
}

enum AutomationTriggerType {
  LEAD_CREATED
  APPOINTMENT_CREATED
  APPOINTMENT_24H_BEFORE
  APPOINTMENT_2H_BEFORE
  APPOINTMENT_REMINDER
  NO_SHOW
  BIRTHDAY
  CUSTOMER_INACTIVE
  ORDER_COMPLETED
  MANUAL
}

enum AutomationLogStatus {
  PENDING
  RUNNING
  SENT
  SUCCESS
  FAILED
  SKIPPED
}

enum IntegrationProvider {
  META_ADS
  GOOGLE_ADS
  ZALO_OA
  SMS
  EMAIL
}

enum IntegrationStatus {
  DISCONNECTED
  CONNECTED
  ERROR
}

enum FacebookAdsConnectionStatus {
  DISCONNECTED
  CONNECTED
  SYNCING
  TOKEN_EXPIRED
  NO_AD_ACCOUNT_ACCESS
  ERROR
}

enum FacebookAdsSyncStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum AdConnectionProvider {
