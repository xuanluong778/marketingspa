// =============================================================================
// Auto Post — Facebook Fanpage scheduling
// =============================================================================

enum AutoPostStatus {
  DRAFT
  PENDING
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

enum AutoPostType {
  SPA_SALES
  BRAND_BUILDING
  CUSTOMER_FEEDBACK
  PROMOTION
  BEAUTY_KNOWLEDGE
  OLD_CUSTOMER_CARE
  OPENING_EVENT
  INBOX_BOOKING
}

enum AutoPostFacebookConnectionStatus {
  CONNECTED
  DISCONNECTED
  TOKEN_EXPIRED
  ERROR
}

model AutoPostFacebookConnection {
  id                   String                           @id @default(uuid())
  userId               String                           @unique @map("user_id")
  organizationId       String                           @map("organization_id")
  encryptedAccessToken String                           @map("encrypted_access_token")
  tokenExpiresAt       DateTime?                        @map("token_expires_at")
  facebookUserId       String?                          @map("facebook_user_id")
  facebookUserName     String?                          @map("facebook_user_name")
  status               AutoPostFacebookConnectionStatus @default(DISCONNECTED)
  scopes               String[]                         @default([])
  lastError            String?                          @map("last_error")
  createdAt            DateTime                         @default(now()) @map("created_at")
  updatedAt            DateTime                         @updatedAt @map("updated_at")

  user  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  pages AutoPostFacebookPage[]

  @@index([organizationId])
  @@map("auto_post_facebook_connections")
}

model AutoPostFacebookPage {
  id                       String   @id @default(uuid())
  userId                   String   @map("user_id")
  connectionId             String   @map("connection_id")
  pageId                   String   @map("page_id")
  pageName                 String   @map("page_name")
  pagePictureUrl           String?  @map("page_picture_url")
  encryptedPageAccessToken String   @map("encrypted_page_access_token")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  connection AutoPostFacebookConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user       User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  posts      AutoPost[]

  @@unique([userId, pageId])
  @@index([userId])
  @@map("auto_post_facebook_pages")
}

model AutoPost {
  id             String         @id @default(uuid())
  userId         String         @map("user_id")
  organizationId String         @map("organization_id")
  fanpageId      String?        @map("fanpage_id")
  fanpagePageId  String?        @map("fanpage_page_id")
  fanpageName    String?        @map("fanpage_name")
  postType       AutoPostType   @map("post_type")
  topic          String
  caption        String         @db.Text
  imageUrl       String?        @map("image_url")
  linkUrl        String?        @map("link_url")
  hashtags       String?        @db.Text
  cta            String?
  spaService     String?        @map("spa_service")
  targetAudience String?        @map("target_audience")
  tone           String?
  promotion      String?
  status         AutoPostStatus @default(DRAFT)
  scheduledAt    DateTime?      @map("scheduled_at")
  publishedAt    DateTime?      @map("published_at")
  facebookPostId String?        @map("facebook_post_id")
  errorMessage   String?        @map("error_message")
  approvedAt     DateTime?      @map("approved_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fanpage     AutoPostFacebookPage? @relation(fields: [fanpageId], references: [id], onDelete: SetNull)
  apiLogs     AutoPostApiLog[]
  publishLogs AutoPostPublishLog[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([status, scheduledAt])
  @@map("auto_posts")
}

model AutoPostApiLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  postId     String?  @map("post_id")
  action     String
  statusCode Int?     @map("status_code")
  errorCode  String?  @map("error_code")
  message    String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post AutoPost? @relation(fields: [postId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([postId])
  @@map("auto_post_api_logs")
}

model AutoPostPublishLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  postId         String   @map("post_id")
  action         String
  status         String
  facebookPostId String?  @map("facebook_post_id")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post AutoPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([postId])
  @@map("auto_post_publish_logs")
}
