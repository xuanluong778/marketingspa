  GOOGLE
  GMAIL
}

enum AdConnectionStatus {
  DISCONNECTED
  CONNECTED
  TOKEN_EXPIRED
  INSUFFICIENT_PERMISSIONS
  ERROR
}

enum AdAutomationRuleType {
  PAUSE_SPEND_NO_CONVERSION
  PAUSE_CPA_THRESHOLD
  PAUSE_ROAS_THRESHOLD
  ALERT_CTR_LOW
  ALERT_CPM_HIGH
  ALERT_CPA_INCREASE
  ALERT_ROAS_DROP
