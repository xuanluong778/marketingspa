  OPEN
  CLOSED
  NEEDS_STAFF
}

enum ChatbotLeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

// =============================================================================
// Core tenancy & RBAC
// =============================================================================

/// Spa / tenant
model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  phone     String?
  email     String?
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branches          Branch[]
  users             User[]
  roles             Role[]
  employees         Employee[]
  departments       Department[]
  employmentContracts EmploymentContract[]
  employeeDocuments EmployeeDocument[]
  employeeAccountInvites EmployeeAccountInvite[]
  workShiftPolicies WorkShiftPolicy[]
  shiftAssignments  ShiftAssignment[]
  attendancePunches AttendancePunch[]
  attendanceDays    AttendanceDay[]
  timesheetPeriods  TimesheetPeriod[]
  attendanceAdjustments AttendanceAdjustment[]
  attendanceQrTokens AttendanceQrToken[]
  leaveRequests     LeaveRequest[]
  overtimeRequests  OvertimeRequest[]
  customers         Customer[]
  leads             Lead[]
  leadSources       LeadSource[]
  funnelStages      FunnelStage[]
  appointments      Appointment[]
  services          Service[]
  orders            Order[]
  payments          Payment[]
  expenses          Expense[]
  adAccounts        AdAccount[]
  adCampaigns       AdCampaign[]
  adDailyStats      AdDailyStat[]
  messageTemplates  MessageTemplate[]
  automationFlows   AutomationFlow[]
  automationLogs    AutomationLog[]
  aiReports         AiReport[]
  auditLogs         AuditLog[]
  subscriptions     Subscription[]
  creditWallet      CreditWallet?
  marketingCampaigns Campaign[]
  integrations      Integration[]
  businessGoalScenarios BusinessGoalScenario[]
  chatbotBots           ChatbotBot[]
  chatbotChannels       ChatbotChannel[]
  chatbotKnowledgeSources ChatbotKnowledgeSource[]
  chatbotConversations  ChatbotConversation[]
  chatbotLeads          ChatbotLead[]
  chatbotUsage          ChatbotUsage[]
  chatbotSettings       ChatbotOrgSettings?
  chatbotFacebookPages  ChatbotFacebookPage[]

  @@map("organizations")
}

model Branch {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  code           String?
  address        String?
  phone          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]
  customers    Customer[]
  leads        Lead[]
  appointments Appointment[]
  orders       Order[]
  expenses     Expense[]
  businessGoalScenarios BusinessGoalScenario[]
  departments  Department[]
  workShiftPolicies WorkShiftPolicy[]
  shiftAssignments ShiftAssignment[]
  attendancePunches AttendancePunch[]
  attendanceDays AttendanceDay[]
  timesheetPeriods TimesheetPeriod[]
  attendanceQrTokens AttendanceQrToken[]
  leaveRequests LeaveRequest[]
  overtimeRequests OvertimeRequest[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("branches")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  module      String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@index([module])
  @@map("permissions")
}

model Role {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  description    String?
  isSystem       Boolean  @default(false) @map("is_system")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users        User[]
  permissions  RolePermission[]
  accountInvites EmployeeAccountInvite[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// MVP: user gắn 1 organization; sau mở rộng qua OrganizationMember
model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  name           String
  organizationId String   @map("organization_id")
  roleId         String   @map("role_id")
  employeeId     String?  @unique @map("employee_id")
  isActive       Boolean  @default(true) @map("is_active")
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id])
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  auditLogs    AuditLog[]
  businessGoalScenarios BusinessGoalScenario[]
  facebookAdsConnection FacebookAdsConnection?
  adConnections         AdConnection[]
  adManagerSettings     AdManagerSettings?
  adAutomationRules     AdAutomationRule[]
  adAutomationLogs      AdAutomationLog[]
  adAiRecommendations   AdAiRecommendation[]
  adEmailReports        AdEmailReport[]
  adDrafts              AdDraft[]
  adInsights            AdInsight[]
  adPlatformAccounts    AdPlatformAccount[]
  adManagerCampaigns    AdManagerCampaign[]
  autoPostFacebookConnection AutoPostFacebookConnection?
  autoPostFacebookPages      AutoPostFacebookPage[]
  autoPosts                  AutoPost[]
  autoPostApiLogs            AutoPostApiLog[]
  autoPostPublishLogs        AutoPostPublishLog[]
  contractsCreated           EmploymentContract[] @relation("ContractCreatedBy")
  documentsUploaded          EmployeeDocument[]   @relation("DocumentUploadedBy")
  accountInvitesCreated      EmployeeAccountInvite[] @relation("AccountInviteCreatedBy")
  timesheetPeriodsLocked     TimesheetPeriod[]    @relation("TimesheetLockedBy")
  shiftPoliciesCreated       WorkShiftPolicy[]    @relation("ShiftPolicyCreatedBy")
  attendanceAdjustmentsCreated AttendanceAdjustment[] @relation("AttendanceAdjustmentBy")
  leaveApprovals             LeaveRequest[]       @relation("LeaveApprover")
  overtimeApprovals          OvertimeRequest[]    @relation("OvertimeApprover")

  @@index([organizationId])
  @@index([roleId])
  @@map("users")
}

model Employee {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  branchId        String?        @map("branch_id")
  departmentId    String?        @map("department_id")
  managerId       String?        @map("manager_id")
  code            String?
  name            String
  phone           String?
  email           String?
  position        String?
  employmentType  EmploymentType @default(FULL_TIME) @map("employment_type")
  status          EmployeeStatus @default(ACTIVE)
  avatarUrl       String?        @map("avatar_url")
  dateOfBirth     DateTime?      @map("date_of_birth")
  legalIdNumber   String?        @map("legal_id_number")
  address         String?
  startDate       DateTime?      @map("start_date")
  endDate         DateTime?      @map("end_date")
  isActive        Boolean        @default(true) @map("is_active")
  hiredAt         DateTime?      @map("hired_at")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch        Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department    Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  manager       Employee?     @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports Employee[]    @relation("EmployeeManager")
  user          User?
  assignedLeads Lead[]        @relation("LeadAssignee")
  appointments  Appointment[]
  contracts     EmploymentContract[]
  documents     EmployeeDocument[]
  accountInvites EmployeeAccountInvite[]
  shiftAssignments ShiftAssignment[]
  attendancePunches AttendancePunch[]
  attendanceDays AttendanceDay[]
  leaveRequests LeaveRequest[]
  overtimeRequests OvertimeRequest[]
  attendanceAdjustments AttendanceAdjustment[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([branchId])
  @@index([departmentId])
  @@index([organizationId, status])
  @@map("employees")
}

model Department {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  branchId       String?  @map("branch_id")
  parentId       String?  @map("parent_id")
  name           String
  code           String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  parent       Department?  @relation("DepartmentTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Department[] @relation("DepartmentTree")
  employees    Employee[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([branchId])
  @@map("departments")
}

model EmploymentContract {
  id                 String                   @id @default(uuid())
  organizationId     String                   @map("organization_id")
  branchId           String?                  @map("branch_id")
  employeeId         String                   @map("employee_id")
  code               String?
  title              String
  contractType       EmploymentContractType   @default(FIXED) @map("contract_type")
  status             EmploymentContractStatus @default(DRAFT)
  salaryBase         Decimal?                 @map("salary_base") @db.Decimal(12, 2)
  currency           String                   @default("VND")
  startDate          DateTime                 @map("start_date")
  endDate            DateTime?                @map("end_date")
  signedAt           DateTime?                @map("signed_at")
  fileUrl            String?                  @map("file_url")
  notes              String?
  version            Int                      @default(1)
  previousContractId String?                  @map("previous_contract_id")
  createdById        String?                  @map("created_by_id")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")

  organization     Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee         Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  previousContract EmploymentContract?  @relation("ContractVersions", fields: [previousContractId], references: [id], onDelete: SetNull)
  nextVersions     EmploymentContract[] @relation("ContractVersions")
  createdBy        User?                @relation("ContractCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId, employeeId])
  @@index([employeeId, status])
  @@map("employment_contracts")
}

model EmployeeDocument {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  branchId       String?         @map("branch_id")
  employeeId     String          @map("employee_id")
  type           HrmDocumentType @default(OTHER)
  title          String
  fileUrl        String          @map("file_url")
  fileKey        String?         @map("file_key")
  mimeType       String?         @map("mime_type")
  sizeBytes      Int?            @map("size_bytes")
  issuedAt       DateTime?       @map("issued_at")
  expiresAt      DateTime?       @map("expires_at")
  uploadedById   String?         @map("uploaded_by_id")
  isArchived     Boolean         @default(false) @map("is_archived")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([organizationId, employeeId])
  @@index([employeeId, type])
  @@map("employee_documents")
}

model EmployeeAccountInvite {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  employeeId     String    @map("employee_id")
  email          String
  roleId         String    @map("role_id")
  tokenHash      String    @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  acceptedAt     DateTime? @map("accepted_at")
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("AccountInviteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId, employeeId])
  @@index([tokenHash])
  @@map("employee_account_invites")
}

model WorkShiftPolicy {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  branchId       String?   @map("branch_id")
  name           String
  code           String?
  effectiveFrom  DateTime  @map("effective_from")
  effectiveTo    DateTime? @map("effective_to")
  currentVersion Int       @default(1) @map("current_version")
  isActive       Boolean   @default(true) @map("is_active")
  createdById    String?   @map("created_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("ShiftPolicyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  versions     WorkShiftPolicyVersion[]
  assignments  ShiftAssignment[]

  @@unique([organizationId, code])
  @@index([organizationId, branchId])
  @@map("work_shift_policies")
}

model WorkShiftPolicyVersion {
  id          String   @id @default(uuid())
  policyId    String   @map("policy_id")
  version     Int
  payload     Json
  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  policy WorkShiftPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, version])
  @@map("work_shift_policy_versions")
}

model ShiftAssignment {
  id             String                @id @default(uuid())
  organizationId String                @map("organization_id")
  branchId       String                @map("branch_id")
  employeeId     String                @map("employee_id")
  policyId       String?               @map("policy_id")
  workDate       DateTime              @map("work_date") @db.Date
  startAt        DateTime              @map("start_at")
  endAt          DateTime              @map("end_at")
  source         ShiftAssignmentSource @default(MANUAL)
  locked         Boolean               @default(false)
  note           String?
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employee     Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policy       WorkShiftPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)

  @@unique([organizationId, employeeId, workDate])
  @@index([organizationId, branchId, workDate])
  @@map("shift_assignments")
}

model AttendanceQrToken {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  branchId       String    @map("branch_id")
  label          String
  tokenHash      String    @map("token_hash")
  isActive       Boolean   @default(true) @map("is_active")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  punches      AttendancePunch[]

  @@index([organizationId, branchId])
  @@index([tokenHash])
  @@map("attendance_qr_tokens")
}

model AttendancePunch {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  branchId       String              @map("branch_id")
  employeeId     String              @map("employee_id")
  workDate       DateTime            @map("work_date") @db.Date
  punchedAt      DateTime            @map("punched_at")
  type           AttendancePunchType
  method         AttendanceMethod
  latitude       Float?
  longitude      Float?
  accuracyM      Float?              @map("accuracy_m")
  qrTokenId      String?             @map("qr_token_id")
  kioskDeviceId  String?             @map("kiosk_device_id")
  rawMetadata    Json?               @map("raw_metadata")
  createdAt      DateTime            @default(now()) @map("created_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employee     Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  qrToken      AttendanceQrToken?   @relation(fields: [qrTokenId], references: [id], onDelete: SetNull)

  @@index([organizationId, employeeId, workDate])
  @@index([organizationId, branchId, punchedAt])
  @@map("attendance_punches")
}

model TimesheetPeriod {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  branchId       String?          @map("branch_id")
  year           Int
  month          Int
  status         TimesheetStatus  @default(OPEN)
  lockedAt       DateTime?        @map("locked_at")
  lockedById     String?          @map("locked_by_id")
  unlockReason   String?          @map("unlock_reason")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  lockedBy     User?        @relation("TimesheetLockedBy", fields: [lockedById], references: [id], onDelete: SetNull)
  attendanceDays AttendanceDay[]
  adjustments  AttendanceAdjustment[]

  @@unique([organizationId, branchId, year, month])
  @@index([organizationId, year, month])
  @@map("timesheet_periods")
}

model AttendanceDay {
  id                 String              @id @default(uuid())
  organizationId     String              @map("organization_id")
  branchId           String              @map("branch_id")
  employeeId         String              @map("employee_id")
  workDate           DateTime            @map("work_date") @db.Date
  checkInAt          DateTime?           @map("check_in_at")
  checkOutAt         DateTime?           @map("check_out_at")
  workedMinutes      Int                 @default(0) @map("worked_minutes")
  lateMinutes        Int                 @default(0) @map("late_minutes")
  earlyLeaveMinutes  Int                 @default(0) @map("early_leave_minutes")
  otMinutes          Int                 @default(0) @map("ot_minutes")
  status             AttendanceDayStatus @default(INCOMPLETE)
  source             String              @default("AUTO")
  timesheetPeriodId  String?             @map("timesheet_period_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch          Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employee        Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  timesheetPeriod TimesheetPeriod? @relation(fields: [timesheetPeriodId], references: [id], onDelete: SetNull)

  @@unique([organizationId, employeeId, workDate])
  @@index([organizationId, branchId, workDate])
  @@index([timesheetPeriodId])
  @@map("attendance_days")
}

model AttendanceAdjustment {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  timesheetPeriodId String   @map("timesheet_period_id")
  employeeId        String   @map("employee_id")
  workDate          DateTime @map("work_date") @db.Date
  field             String
  oldValue          String?  @map("old_value")
  newValue          String?  @map("new_value")
  reason            String
  createdById       String?  @map("created_by_id")
  createdAt         DateTime @default(now()) @map("created_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timesheetPeriod TimesheetPeriod @relation(fields: [timesheetPeriodId], references: [id], onDelete: Cascade)
  employee        Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy       User?           @relation("AttendanceAdjustmentBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([organizationId, timesheetPeriodId])
  @@index([employeeId, workDate])
  @@map("attendance_adjustments")
}

model LeaveRequest {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  branchId       String?            @map("branch_id")
  employeeId     String             @map("employee_id")
  leaveType      LeaveType          @map("leave_type")
  fromDate       DateTime           @map("from_date") @db.Date
  toDate         DateTime           @map("to_date") @db.Date
  days           Decimal            @db.Decimal(5, 1)
  status         LeaveRequestStatus @default(PENDING)
  reason         String?
  approverId     String?            @map("approver_id")
  decidedAt      DateTime?          @map("decided_at")
  decisionNote   String?            @map("decision_note")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver     User?        @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([employeeId, fromDate])
  @@map("leave_requests")
}

model OvertimeRequest {
  id             String             @id @default(uuid())
  organizationId String             @map("organization_id")
  branchId       String             @map("branch_id")
  employeeId     String             @map("employee_id")
  workDate       DateTime           @map("work_date") @db.Date
  minutes        Int
  reason         String?
  status         LeaveRequestStatus @default(PENDING)
  approverId     String?            @map("approver_id")
  decidedAt      DateTime?          @map("decided_at")
  decisionNote   String?            @map("decision_note")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approver     User?        @relation("OvertimeApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([employeeId, workDate])
  @@map("overtime_requests")
}

// =============================================================================
// CRM — Customer & Lead pipeline
// =============================================================================

model LeadSource {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  code           String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customers    Customer[]
  leads        Lead[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@map("lead_sources")
}

model FunnelStage {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  position       Int      @default(0)
  color          String?
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads        Lead[]

  @@unique([organizationId, name])
  @@index([organizationId, position])
  @@map("funnel_stages")
}

model Customer {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  branchId       String?   @map("branch_id")
  leadSourceId   String?   @map("lead_source_id")
  name           String
  phone          String?
  email          String?
  gender         Gender    @default(UNKNOWN)
  birthday       DateTime? @db.Date
  note           String?
  tags           String[]  @default([])
  source         String? /// legacy/free-text source nếu chưa map LeadSource
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch              Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  leadSource          LeadSource?          @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  leads               Lead[]
  appointments        Appointment[]
  orders              Order[]
  automationLogs      AutomationLog[]
  marketingCampaigns  CampaignCustomer[]

  @@index([organizationId])
  @@index([organizationId, phone])
  @@index([branchId])
  @@map("customers")
}

model Lead {
  id               String             @id @default(uuid())
  organizationId   String             @map("organization_id")
  branchId         String?            @map("branch_id")
  leadSourceId     String?            @map("lead_source_id")
  funnelStageId    String?            @map("funnel_stage_id")
  assignedToId     String?            @map("assigned_to_id")
  customerId       String?            @map("customer_id")
  name             String
  phone            String?
  email            String?
  pipelineStatus   LeadPipelineStatus @default(NEW) @map("pipeline_status")
  note             String?
  estimatedValue   Decimal?           @map("estimated_value") @db.Decimal(12, 2)
  lostReason       String?            @map("lost_reason")
  convertedAt      DateTime?          @map("converted_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch         Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  leadSource     LeadSource?     @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  funnelStage    FunnelStage?    @relation(fields: [funnelStageId], references: [id], onDelete: SetNull)
  assignedTo     Employee?       @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  appointments   Appointment[]
  automationLogs AutomationLog[]

  @@index([organizationId, pipelineStatus])
  @@index([assignedToId])
  @@index([customerId])
  @@map("leads")
}

// =============================================================================
// Operations — Appointment, Service, Order, Payment, Expense
// =============================================================================

model Service {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  name            String
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  durationMinutes Int      @default(60) @map("duration_minutes")
  category        String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  orderItems    OrderItem[]

  @@index([organizationId])
  @@map("services")
}

model Appointment {
  id              String            @id @default(uuid())
  organizationId  String            @map("organization_id")
  branchId        String            @map("branch_id")
  customerId      String?           @map("customer_id")
  leadId          String?           @map("lead_id")
  employeeId      String?           @map("employee_id")
  serviceId       String?           @map("service_id")
  scheduledAt     DateTime          @map("scheduled_at")
  durationMinutes Int               @default(60) @map("duration_minutes")
  status          AppointmentStatus @default(SCHEDULED)
  note            String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead         Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  service      Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([organizationId, scheduledAt])
  @@index([branchId, status])
  @@map("appointments")
}

model Order {
  id             String      @id @default(uuid())
  organizationId String      @map("organization_id")
  branchId       String?     @map("branch_id")
  customerId     String      @map("customer_id")
  orderNumber    String      @map("order_number")
  status         OrderStatus @default(PENDING)
  subtotal       Decimal     @default(0) @db.Decimal(12, 2)
  discount       Decimal     @default(0) @db.Decimal(12, 2)
  total          Decimal     @default(0) @db.Decimal(12, 2)
  note           String?
  orderedAt      DateTime    @default(now()) @map("ordered_at")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items        OrderItem[]
  payments     Payment[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, orderedAt])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String  @map("order_id")
  serviceId  String? @map("service_id")
  name       String
  quantity   Int     @default(1)
  unitPrice  Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice Decimal @map("total_price") @db.Decimal(12, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  orderId        String        @map("order_id")
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod @default(CASH)
  status         PaymentStatus @default(PENDING)
  reference      String?
  paidAt         DateTime?     @map("paid_at")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, paidAt])
  @@index([orderId])
  @@map("payments")
}

model Expense {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  branchId       String?         @map("branch_id")
  adCampaignId   String?         @map("ad_campaign_id")
  category       ExpenseCategory
  description    String
  amount         Decimal         @db.Decimal(12, 2)
  expenseDate    DateTime        @map("expense_date") @db.Date
  note           String?
  createdAt      DateTime        @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  branch       Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  adCampaign   AdCampaign?  @relation(fields: [adCampaignId], references: [id], onDelete: SetNull)

  @@index([organizationId, expenseDate])
  @@index([category])
  @@map("expenses")
}

// =============================================================================
// Advertising — manual input trước, sau kết nối Meta/Google API
// =============================================================================

model AdAccount {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  platform       AdPlatform
  name           String
  externalId     String?    @map("external_id")
  currency       String     @default("VND")
  isActive       Boolean    @default(true) @map("is_active")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  campaigns    AdCampaign[]

  @@index([organizationId, platform])
  @@map("ad_accounts")
}

model AdCampaign {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  adAccountId    String           @map("ad_account_id")
  name           String
  platform       AdPlatform
  status         AdCampaignStatus @default(DRAFT)
  budget         Decimal?         @db.Decimal(12, 2)
  startDate      DateTime?        @map("start_date") @db.Date
  endDate        DateTime?        @map("end_date") @db.Date
  externalId     String?          @map("external_id")
  note           String?
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adAccount    AdAccount     @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  dailyStats   AdDailyStat[]
  expenses     Expense[]

  @@index([organizationId, status])
  @@index([adAccountId])
  @@map("ad_campaigns")
}

model AdDailyStat {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  adCampaignId   String   @map("ad_campaign_id")
  date           DateTime @db.Date
  impressions    Int      @default(0)
  clicks         Int      @default(0)
  spend          Decimal  @default(0) @db.Decimal(12, 2)
  leads          Int      @default(0)
  conversions    Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  adCampaign   AdCampaign   @relation(fields: [adCampaignId], references: [id], onDelete: Cascade)

  @@unique([adCampaignId, date])
  @@index([organizationId, date])
  @@map("ad_daily_stats")
}

// =============================================================================
// Marketing automation & messaging
// =============================================================================

model MessageTemplate {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  name           String
  channel        MessageChannel
  subject        String?
  body           String
  variables      Json           @default("[]")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  automationFlows AutomationFlow[]

  @@index([organizationId, channel])
  @@map("message_templates")
}

model AutomationFlow {
  id                String                @id @default(uuid())
  organizationId    String                @map("organization_id")
  messageTemplateId String?               @map("message_template_id")
  name              String
  triggerType       AutomationTriggerType @map("trigger_type")
  channel           MessageChannel?       @map("channel")
  delayMinutes      Int                   @default(0) @map("delay_minutes")
  triggerConfig     Json                  @default("{}") @map("trigger_config")
  isActive          Boolean               @default(true) @map("is_active")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messageTemplate MessageTemplate? @relation(fields: [messageTemplateId], references: [id], onDelete: SetNull)
  logs            AutomationLog[]

  @@index([organizationId, triggerType])
  @@map("automation_flows")
}

model AutomationLog {
  id               String              @id @default(uuid())
  organizationId   String              @map("organization_id")
  automationFlowId String              @map("automation_flow_id")
  customerId       String?             @map("customer_id")
  leadId           String?             @map("lead_id")
  channel          MessageChannel?     @map("channel")
  renderedContent  String?             @map("rendered_content")
  status           AutomationLogStatus @default(PENDING)
  result           Json?
  executedAt       DateTime?           @map("executed_at")
  createdAt        DateTime            @default(now()) @map("created_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  automationFlow AutomationFlow @relation(fields: [automationFlowId], references: [id], onDelete: Cascade)
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([automationFlowId])
  @@map("automation_logs")
}

/// Marketing / messaging provider credentials (encrypted at rest)
model Integration {
  id                   String              @id @default(uuid())
  organizationId       String              @map("organization_id")
  provider             IntegrationProvider
  status               IntegrationStatus   @default(DISCONNECTED)
  encryptedCredentials String?             @map("encrypted_credentials")
  metadata             Json                @default("{}")
  lastTestedAt         DateTime?           @map("last_tested_at")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@map("integrations")
}

/// Kết nối Facebook Ads theo user (tab Hiệu quả quảng cáo)
model FacebookAdsConnection {
  id                    String                      @id @default(uuid())
  userId                String                      @unique @map("user_id")
  organizationId        String                      @map("organization_id")
  encryptedAccessToken  String                      @map("encrypted_access_token")
  tokenExpiresAt        DateTime?                   @map("token_expires_at")
  facebookUserId        String?                     @map("facebook_user_id")
  selectedAdAccountId   String?                     @map("selected_ad_account_id")
  selectedAdAccountName String?                     @map("selected_ad_account_name")
  status                FacebookAdsConnectionStatus @default(DISCONNECTED)
  scopes                String[]                    @default([])
  lastSyncAt            DateTime?                   @map("last_sync_at")
  lastSyncStatus        FacebookAdsSyncStatus?      @map("last_sync_status")
  lastSyncError         String?                     @map("last_sync_error")
  createdAt             DateTime                    @default(now()) @map("created_at")
  updatedAt             DateTime                    @updatedAt @map("updated_at")

  user              User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncLogs          FacebookAdsSyncLog[]
  campaignSnapshots FacebookAdsCampaignSnapshot[]

  @@index([organizationId])
  @@map("facebook_ads_connections")
}

model FacebookAdsSyncLog {
  id              String                @id @default(uuid())
  userId          String                @map("user_id")
  adAccountId     String                @map("ad_account_id")
  dateFrom        DateTime              @map("date_from") @db.Date
  dateTo          DateTime              @map("date_to") @db.Date
  syncStartedAt   DateTime              @map("sync_started_at")
  syncFinishedAt  DateTime?             @map("sync_finished_at")
  status          FacebookAdsSyncStatus
  errorMessage    String?               @map("error_message")
  campaignsSynced Int                   @default(0) @map("campaigns_synced")

  connection FacebookAdsConnection @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, syncStartedAt])
  @@map("facebook_ads_sync_logs")
}

model FacebookAdsCampaignSnapshot {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  adAccountId   String   @map("ad_account_id")
  campaignId    String   @map("campaign_id")
  campaignName  String   @map("campaign_name")
  objective     String?
  campaignType  String   @map("campaign_type")
  dateFrom      DateTime @map("date_from") @db.Date
  dateTo        DateTime @map("date_to") @db.Date
  spend         Decimal  @default(0) @db.Decimal(14, 2)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  frequency     Decimal  @default(0) @db.Decimal(10, 4)
  cpm           Decimal  @default(0) @db.Decimal(14, 4)
  cpc           Decimal  @default(0) @db.Decimal(14, 4)
  ctr           Decimal  @default(0) @db.Decimal(10, 4)
  clicks        Int      @default(0)
  results       Decimal  @default(0) @db.Decimal(14, 2)
  costPerResult Decimal  @default(0) @map("cost_per_result") @db.Decimal(14, 4)
  purchaseRoas  Decimal? @map("purchase_roas") @db.Decimal(14, 4)
  resultRate    Decimal  @default(0) @map("result_rate") @db.Decimal(10, 4)
  syncedAt      DateTime @map("synced_at")

  connection FacebookAdsConnection @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, campaignId, dateFrom, dateTo])
  @@index([userId, adAccountId])
  @@map("facebook_ads_campaign_snapshots")
}

/// Marketing message campaign (queue worker) — tách biệt AdCampaign
model Campaign {
  id             String                  @id @default(uuid())
  organizationId String                  @map("organization_id")
  name           String
  status         MarketingCampaignStatus @default(DRAFT)
  channel        MessageChannel
  scheduledAt    DateTime?               @map("scheduled_at")
  sentCount      Int                     @default(0) @map("sent_count")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customers    CampaignCustomer[]

  @@index([organizationId, status])
  @@map("campaigns")
}

model CampaignCustomer {
  campaignId String @map("campaign_id")
  customerId String @map("customer_id")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@id([campaignId, customerId])
  @@map("campaign_customers")
}

// =============================================================================
// AI, audit, billing
// =============================================================================

model AiReport {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  type           String
  title          String
  content        Json
  generatedAt    DateTime @default(now()) @map("generated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@map("ai_reports")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  userId         String?  @map("user_id")
  action         String
  entityType     String   @map("entity_type")
  entityId       String?  @map("entity_id")
  metadata       Json?
  ipAddress      String?  @map("ip_address")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model SubscriptionPlan {
  id              String   @id @default(uuid())
  code            String   @unique
  name            String
  priceMonthly    Decimal  @map("price_monthly") @db.Decimal(12, 2)
  creditsIncluded Int      @default(0) @map("credits_included")
  features        Json     @default("[]")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                 String             @id @default(uuid())
  organizationId     String             @map("organization_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
