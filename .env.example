# =============================================================================
# MarketingSpa - Environment Variables (copy to .env and adjust)
# =============================================================================

# --- General ---
NODE_ENV=development
APP_NAME=MarketingSpa
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- PostgreSQL ---
POSTGRES_USER=marketingspa
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=marketingspa
DATABASE_URL=postgresql://marketingspa:change_me_strong_password@localhost:5432/marketingspa?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# --- JWT / Auth ---
JWT_SECRET=change_me_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d

# HRM Phase 0 — PermissionsGuard (false = shadow log only, không block)
HRM_PERMISSIONS_ENFORCE=true

# --- Credential encryption (integrations API keys) ---
ENCRYPTION_KEY=change_me_encryption_key_min_32_chars

# --- Meta / Facebook Ads + Auto Post Fanpage ---
META_APP_ID=
META_APP_SECRET=
# Bắt buộc với app Business (Facebook Login for Business, vd. app seoauto).
# Lấy tại Meta Dashboard → Facebook Login for Business → Configurations → Configuration ID
# (alias: FACEBOOK_LOGIN_CONFIG_ID / FACEBOOK_CONFIG_ID)
META_LOGIN_CONFIG_ID=
META_API_VERSION=v21.0
META_REDIRECT_URI=http://localhost:4000/api/v1/ad-performance/facebook/oauth/callback
# OAuth callback riêng cho Auto Post Fanpage (phải thêm vào Valid OAuth Redirect URIs)
META_AUTO_POST_REDIRECT_URI=http://localhost:4000/api/v1/auto-post/facebook/oauth/callback
# Tuỳ chọn: ghi đè scope khi KHÔNG dùng META_LOGIN_CONFIG_ID
# META_AUTO_POST_SCOPES=pages_show_list,pages_manage_metadata,pages_read_engagement,pages_manage_posts

# --- Chatbot CSKH — Messenger (chỉ cần Page Access Token, không cần META_APP_ID) ---
# Callback URL: {API_URL}/api/v1/chatbot-cskh/facebook/webhook
CSKH_FB_WEBHOOK_VERIFY_TOKEN=marketingspa_cskh_fb
# Trong app: dán Page ID + Page Access Token (Messenger) là đủ

# --- Meta Fanpage đăng bài trực tiếp (token Page chỉ trên backend) ---
META_GRAPH_VERSION=v21.0
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=

# --- Next.js (apps/web) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# URL API công khai cho mã nhúng chatbot (HTTPS cùng domain website, vd. https://backlinkbrand.com/chatbot-api)
CHATBOT_PUBLIC_API_URL=https://backlinkbrand.com/chatbot-api
CHATBOT_PROXY_PATH=chatbot-api
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# --- Sentry (placeholder - configure in production) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# --- BullMQ / Worker ---
QUEUE_PREFIX=marketingspa

# --- AI Service (placeholder) ---
AI_SERVICE_URL=http://localhost:8000

# --- OpenAI (chatbot CSKH + gợi ý AI) ---
# Lấy key tại https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Tùy chọn: proxy/Azure (vd. https://api.openai.com/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# --- Nginx / SSL (production VPS) ---
DOMAIN=your-domain.com
SSL_EMAIL=admin@your-domain.com

# --- Backup ---
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7

# --- Worker ---
STALE_LEAD_MINUTES=10
